---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import SectionTitle from '../components/SectionTitle.astro';
import '../styles/global.css';
---

<Layout title="PRO STOPY — Професійний подолог у Києві | Подологічний догляд">
  <!-- Hero Section -->
  <section class="hero-section relative overflow-hidden">
    <!-- Decorative blobs from brand guideline -->
    <div class="absolute top-[-80px] right-[-60px] w-[300px] h-[300px] rounded-full bg-base-3/20 blur-3xl"></div>
    <div class="absolute bottom-[-100px] left-[-80px] w-[400px] h-[400px] rounded-full bg-base-2/15 blur-3xl"></div>
    <div class="absolute top-1/2 right-1/4 w-[200px] h-[200px] rounded-full bg-base-5/10 blur-2xl"></div>

    <div class="container-custom relative z-10 py-24 md:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-prosto text-dark mb-6 text-balance leading-tight">
            Професійний догляд за вашими стопами
          </h1>
          <p class="text-xl text-gray mb-10 max-w-xl leading-relaxed">
            Подологічна студія в ЖК Seven — Позняки, Осокорки. Індивідуальний підхід, сучасні методики, бездоганний результат.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <Button href="tel:+380985279475" size="lg" variant="primary">
              Записатися на прийом
            </Button>
            <Button href="https://www.instagram.com/podolog_datsyshyna" size="lg" variant="secondary">
              Instagram
            </Button>
          </div>
        </div>

        <!-- Stats / Trust cards -->
        <div class="grid grid-cols-2 gap-5">
          <div class="stat-card bg-white/70 rounded-2xl p-6 backdrop-blur-sm border border-white/50 shadow-lg">
            <div class="w-12 h-12 bg-base-2/30 rounded-full flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-base-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="text-2xl font-prosto text-dark mb-1">10+</div>
            <div class="text-gray text-sm">послуг для здоров'я стоп</div>
          </div>
          <div class="stat-card bg-white/70 rounded-2xl p-6 backdrop-blur-sm border border-white/50 shadow-lg">
            <div class="w-12 h-12 bg-base-3/30 rounded-full flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-base-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="text-2xl font-prosto text-dark mb-1">1000+</div>
            <div class="text-gray text-sm">задоволених клієнтів</div>
          </div>
          <div class="stat-card bg-white/70 rounded-2xl p-6 backdrop-blur-sm border border-white/50 shadow-lg">
            <div class="w-12 h-12 bg-base-1/30 rounded-full flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-base-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="text-2xl font-prosto text-dark mb-1">100%</div>
            <div class="text-gray text-sm">стерильність</div>
          </div>
          <div class="stat-card bg-white/70 rounded-2xl p-6 backdrop-blur-sm border border-white/50 shadow-lg">
            <div class="w-12 h-12 bg-base-5/30 rounded-full flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-base-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="text-2xl font-prosto text-dark mb-1">5.0</div>
            <div class="text-gray text-sm">рейтинг у Google</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="section-padding bg-white">
    <div class="container-custom">
      <SectionTitle
        title="Наші послуги"
        subtitle="Професійний підхід до кожної процедури. Підбираємо оптимальне рішення, виходячи зі стану ваших стоп."
        class="mb-16"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Гігієнічний педикюр -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-accent/40 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-accent transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Гігієнічний педикюр</h3>
          <p class="text-gray text-sm leading-relaxed">Базова процедура для підтримання чистоти та здоров'я стоп. Делікатно видаляємо ороговілу шкіру, надаємо естетичний вигляд нігтям.</p>
        </div>

        <!-- Подологічний педикюр -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-base-2/30 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-base-2/60 transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1 3.39a1.5 1.5 0 01-2.32-1.26V6.7a1.5 1.5 0 012.32-1.26l5.1 3.39m0 0l5.1 3.39a1.5 1.5 0 010 2.52l-5.1 3.39"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Подологічний педикюр</h3>
          <p class="text-gray text-sm leading-relaxed">Комплексна професійна обробка стопи з урахуванням індивідуальних проблем: гіперкератози, врослі чи деформовані нігті, мозолі та тріщини.</p>
        </div>

        <!-- Обробка мозолів -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-base-3/30 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-base-3/60 transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Обробка мозолів</h3>
          <p class="text-gray text-sm leading-relaxed">Безболісно та акуратно видаляємо мозолі будь-якої складності, усуваємо дискомфорт і допомагаємо запобігти їх повторному утворенню.</p>
        </div>

        <!-- Обробка тріщин -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-base-1/30 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-base-1/60 transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Обробка тріщин</h3>
          <p class="text-gray text-sm leading-relaxed">Догляд за пошкодженою шкірою стоп. М'яке очищення, шліфування та професійний догляд, що сприяє швидшому загоєнню та відновленню.</p>
        </div>

        <!-- Врослий ніготь -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-base-5/30 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-base-5/60 transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Обробка врослого нігтя</h3>
          <p class="text-gray text-sm leading-relaxed">Акуратно усуваємо проблему без хірургічного втручання. Сучасні подологічні методи для зняття болю, корекції росту та профілактики.</p>
        </div>

        <!-- Деформовані нігті -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-accent/40 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-accent transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1 3.39a1.5 1.5 0 01-2.32-1.26V6.7a1.5 1.5 0 012.32-1.26l5.1 3.39m7.5-3.39v12.54a1.5 1.5 0 01-2.32 1.26l-5.1-3.39"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Деформовані нігті</h3>
          <p class="text-gray text-sm leading-relaxed">Корекція нігтьових пластин, що змінили форму через травми, грибкові ураження чи інші причини. Надаємо нігтям природний вигляд.</p>
        </div>

        <!-- Грибок нігтів -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-base-2/30 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-base-2/60 transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Грибок нігтів та мікоз</h3>
          <p class="text-gray text-sm leading-relaxed">Комплексний підхід: апаратна обробка уражених нігтів і шкіри, поєднана з правильним підбором засобів для домашнього догляду.</p>
        </div>

        <!-- Бородавки -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-base-3/30 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-base-3/60 transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Обробка бородавок</h3>
          <p class="text-gray text-sm leading-relaxed">Апаратна та професійна обробка бородавок на стопах із використанням спеціальних методів, що допомагають безпечно зняти дискомфорт.</p>
        </div>

        <!-- Устілки -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-base-1/30 rounded-2xl flex items-center justify-center mb-5 group-hover:bg-base-1/60 transition-colors">
            <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-prosto text-dark mb-3">Розвантажувальні устілки</h3>
          <p class="text-gray text-sm leading-relaxed">Індивідуальні устілки для зменшення надмірного тиску на окремі ділянки стопи. Підвищення комфорту під час ходьби.</p>
        </div>

        <!-- Космецевтика -->
        <div class="service-card group bg-white rounded-2xl p-7 border border-base-6/40 hover:border-accent hover:shadow-xl transition-all duration-300 md:col-span-2 lg:col-span-3">
          <div class="flex flex-col md:flex-row md:items-center gap-5">
            <div class="w-14 h-14 bg-base-5/30 rounded-2xl flex items-center justify-center flex-shrink-0 group-hover:bg-base-5/60 transition-colors">
              <svg class="w-7 h-7 text-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-prosto text-dark mb-2">Підбір та продаж космецевтики</h3>
              <p class="text-gray text-sm leading-relaxed">Рекомендуємо професійні засоби для догляду за стопами та нігтями. Підбираємо індивідуально для вирішення конкретних проблем: сухість, тріщини, грибкові ураження, надмірна пітливість.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section-padding relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 bg-gradient-to-br from-base-6/10 via-white to-accent/10"></div>

    <div class="container-custom relative z-10">
      <SectionTitle
        title="Чому обирають нас"
        subtitle=""
        class="mb-16"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 bg-accent rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-dark" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-prosto text-dark mb-2">Досвід та кваліфікація</h3>
              <p class="text-gray leading-relaxed">Постійне підвищення кваліфікації та сертифіковані методики догляду за стопами.</p>
            </div>
          </div>

          <div class="flex items-start gap-5">
            <div class="w-12 h-12 bg-base-2/40 rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-dark" fill="currentColor" viewBox="0 0 20 20">
