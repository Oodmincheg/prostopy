<script>
  document.querySelectorAll('.review-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const container = btn.closest('.review-toggle');
      const textEl = container?.querySelector('.review-text') as HTMLElement;
      if (!textEl) return;
      const translated = textEl.dataset.translated ?? '';
      const original = textEl.dataset.original ?? '';
      const showOriginal = btn.getAttribute('data-show-original') ?? 'Show original';
      const showTranslation = btn.getAttribute('data-show-translation') ?? 'Show translation';
      const isShowingTranslation = textEl.textContent?.trim() === translated.trim();
      textEl.textContent = isShowingTranslation ? original : translated;
      btn.textContent = isShowingTranslation ? showTranslation : showOriginal;
    });
  });
</script>
