---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import '../styles/global.css';
---

<Layout title="404 — PRO STOPY" description="Page not found">
  <section class="section-padding bg-white min-h-[60vh] flex items-center">
    <div class="container-custom text-center">
      <div class="max-w-lg mx-auto">
        <div class="text-8xl font-prosto text-accent mb-6">404</div>
        <h1 class="text-2xl md:text-3xl font-prosto text-dark mb-4">
          Сторінку не знайдено / Page not found
        </h1>
        <p class="text-gray mb-8 leading-relaxed">
          Ця сторінка не існує або була переміщена.<br/>
          This page doesn't exist or has been moved.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/" size="lg" variant="primary">
            Головна / Home
          </Button>
          <Button href="/en/" size="lg" variant="secondary">
            English version
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
