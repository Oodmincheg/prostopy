---
export interface Props {
  variant?: 'light' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  variant = 'dark',
  size = 'md',
  class: className = '',
} = Astro.props;

const sizeMap = {
  sm: 'h-14 md:h-20',
  md: 'h-20 md:h-28',
  lg: 'h-28 md:h-36'
};

const src = variant === 'light' ? '/logo-dark.png' : '/logo.png';
const blendMode = variant === 'light' ? 'mix-blend-screen' : '';
const h = sizeMap[size];
---

<img src={src} alt="PRO STOPY" class={`${h} w-auto ${blendMode} ${className}`.trim()} />
